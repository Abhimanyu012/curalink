# ─────────────────────────────────────────
#  Curalink Server — Environment Variables
#  Copy this file to .env and fill in your values
# ─────────────────────────────────────────

# Server
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# MongoDB (optional — conversation history)
# Leave blank to disable history persistence
MONGO_URI=mongodb://localhost:27017/curalink

# Hugging Face — get a free token at https://huggingface.co/settings/tokens
HF_API_TOKEN=hf_your_token_here

# HF model to use (instruction-tuned models only)
# Options: mistralai/Mistral-7B-Instruct-v0.3
#          HuggingFaceH4/zephyr-7b-beta
#          meta-llama/Meta-Llama-3-8B-Instruct
HF_MODEL=mistralai/Mistral-7B-Instruct-v0.3
